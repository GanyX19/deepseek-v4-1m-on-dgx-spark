# Copy to .env and fill in. NEVER commit .env (see .gitignore).

# --- Cluster topology (your two DGX Spark nodes) ---
# Head + worker addresses on the high-speed interconnect (e.g. RoCEv2 /30 link).
HEAD_IP=10.0.0.1
WORKER_IP=10.0.0.2
# NCCL master port for the TP group.
MASTER_PORT=29501

# --- Model source ---
# DeepSeek-V4-Flash is a gated model; set your Hugging Face token to pull weights.
HF_TOKEN=

# --- Image tag produced by build/ ---
VLLM_IMAGE=vllm-gb10-dsv4
